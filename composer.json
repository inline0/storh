{
    "name": "storh/storh",
    "description": "File-first records for PHP: JSONC document store, append-only segmented log, and log-backed queue. Zero dependencies.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "inline0",
            "homepage": "https://github.com/inline0"
        }
    ],
    "homepage": "https://github.com/inline0/storh",
    "support": {
        "issues": "https://github.com/inline0/storh/issues",
        "source": "https://github.com/inline0/storh"
    },
    "keywords": [
        "php",
        "storage",
        "datastore",
        "jsonc",
        "document-store",
        "append-only-log",
        "queue",
        "uuidv7",
        "file-storage",
        "zero-dependency"
    ],
    "require": {
        "php": "^8.2",
        "ext-json": "*"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^13.1",
        "squizlabs/php_codesniffer": "^3.11"
    },
    "autoload": {
        "psr-4": {
            "Storh\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Storh\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "process-timeout": 0,
        "sort-packages": true
    },
    "bin": [
        "bin/storh"
    ],
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite=unit",
        "test:integration": "phpunit --testsuite=integration",
        "test:coverage": "XDEBUG_MODE=coverage phpunit --coverage-text --colors=never",
        "test:coverage:clover": "mkdir -p build && XDEBUG_MODE=coverage phpunit --coverage-clover build/clover.xml --colors=never",
        "test:coverage:gate": [
            "@test:coverage:clover",
            "php tools/coverage-gate.php build/clover.xml --min-lines=85 --min-methods=70"
        ],
        "bench": "php bench/bench.php",
        "bench:jit": "XDEBUG_MODE=off php -d opcache.enable_cli=1 -d opcache.jit=tracing -d opcache.jit_buffer_size=128M bench/bench.php",
        "bench:ci": "php bench/ci.php",
        "bench:compare": "php bench/compare.php",
        "bench:gate": "php bench/gate.php",
        "bench:range": "php bench/range.php",
        "bench:repeat": "php bench/repeat.php",
        "analyse": "phpstan analyse --configuration=phpstan.neon.dist --memory-limit=512M",
        "cs": "phpcs --warning-severity=0",
        "cs:fix": "phpcbf",
        "verify": [
            "@analyse",
            "@cs",
            "@test"
        ]
    }
}
